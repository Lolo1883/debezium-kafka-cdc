# =============================================================================
# KEP CDC Stack — environment variables
# Copy this file to .env and fill in all values before running docker compose
# NEVER commit .env to version control
# =============================================================================

# ── Kafka ─────────────────────────────────────────────────────────────────────
# The public IP or hostname of this VM (used in KAFKA_ADVERTISED_LISTENERS)
KAFKA_HOST=<THIS_VM_PUBLIC_IP_OR_HOSTNAME>

# ── PostgreSQL source (Scaleway managed PG) ───────────────────────────────────
PG_HOST=<SCALEWAY_PG_HOST>
PG_PORT=5432
PG_DATABASE=<POSTGRES_DATABASE_NAME>
PG_USER=debezium_user
PG_PASSWORD=<DEBEZIUM_USER_PASSWORD>

# ── MSSQL sink (Hetzner Windows Server) ───────────────────────────────────────
MSSQL_HOST=<HETZNER_MSSQL_HOST>
MSSQL_PORT=1433
MSSQL_DATABASE=<TARGET_DATABASE_NAME>
MSSQL_USER=debezium_sink
MSSQL_PASSWORD=<SINK_USER_PASSWORD>

# ── Kafka Connect ─────────────────────────────────────────────────────────────
# Comma-separated list of tables: public.table1,public.table2
TABLES=public.<TABLE_1>,public.<TABLE_2>

# Short prefix for Kafka topic names — topics will be: <PREFIX>.public.<table>
TOPIC_PREFIX=kep
